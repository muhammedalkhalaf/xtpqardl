Package: xtpqardl
Type: Package
Title: Panel Quantile Autoregressive Distributed Lag Model
Version: 1.0.1
Date: 2026-02-20
Authors@R: c(
    person("Muhammad", "Alkhalaf", 
           email = "muhammedalkhalaf@gmail.com",
           role = c("aut", "cre", "cph"),
